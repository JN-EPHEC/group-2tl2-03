{
"compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ESNext",
    "module": "NodeNext",           
    "moduleResolution": "NodeNext", 
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "strict": false 
  },
  "include": ["src/**/*", "../web/src/services/api.js"],
  "exclude": ["src/tests/**/*", "**/*.test.ts"]
}